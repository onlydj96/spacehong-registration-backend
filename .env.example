PORT=4000
NODE_ENV=development

SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-service-key

# Admin email whitelist (comma-separated)
# Users with these emails can access admin panel
ADMIN_EMAILS=admin@example.com,manager@example.com

# Development
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# Production - add your Vercel domain (comma-separated)
# ALLOWED_ORIGINS=https://your-app.vercel.app,https://spaceghong-registration.vercel.app
